# default: detect text files, normalize to LF on commit and checkout
* text=auto eol=lf

# force LF for source and config (never want CRLF, even on Windows)
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf

# Windows batch/cmd files require CRLF to execute correctly
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# binary assets (no line-ending conversion, no diff)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.db binary
*.sqlite binary
*.sqlite3 binary
*.mp3 binary
*.mp4 binary
*.mov binary
*.wav binary
*.webm binary
*.mkv binary
