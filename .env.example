# ──────────────────────────────────────────────────────────
# SECURITY WARNING: All values below are dev defaults.
# For production, replace ALL credentials with strong,
# unique values. Never deploy with these defaults.
# ──────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────
# Infrastructure (docker compose)
# ──────────────────────────────────────────────────────────

# postgres
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom_dev
POSTGRES_DB=loom
POSTGRES_PORT=5432
POSTGRES_BIND=127.0.0.1

# minio
MINIO_ROOT_USER=loom_minio
MINIO_ROOT_PASSWORD=loom_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BIND=127.0.0.1

# temporal
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
TEMPORAL_BIND=127.0.0.1

# ──────────────────────────────────────────────────────────
# Backend (LOOM_ prefix; see backend/src/loom/config.py)
# ──────────────────────────────────────────────────────────

# deployment profile: "server" (dockerized postgres + minio +
# temporal) or "lite" (sqlite + local filesystem + in-process
# worker, used by the Tauri desktop shell).
LOOM_DEPLOYMENT_PROFILE=server

# lite-profile only: root directory for originals, derivatives,
# and the sqlite db. defaults to ~/.loom/data when unset.
# LOOM_DATA_DIR=

# core connections
LOOM_DATABASE_URL=postgresql+asyncpg://loom:loom_dev@localhost:5432/loom
LOOM_MINIO_ENDPOINT=localhost:9000
LOOM_MINIO_ACCESS_KEY=loom_minio
LOOM_MINIO_SECRET_KEY=loom_minio_dev
LOOM_MINIO_SECURE=false
LOOM_TEMPORAL_HOST=localhost:7233
LOOM_TEMPORAL_NAMESPACE=loom

# auth. secret_key must be ≥32 chars and must NOT be the literal
# default "change-me-in-production" — startup will refuse to boot.
LOOM_SECRET_KEY=change-me-in-production
LOOM_ACCESS_TOKEN_EXPIRE_MINUTES=15
LOOM_REFRESH_TOKEN_EXPIRE_DAYS=7

# cors: JSON array of absolute http(s) origins. "*" is rejected;
# each entry must have scheme + host and no path.
LOOM_CORS_ORIGINS=["http://localhost:3000"]

# lite-profile only: per-install random secret used to sign
# loopback presigned URLs. the Tauri shell provisions this on
# first run via tauri-plugin-store.
# LOOM_STORAGE_SIGNING_SECRET=

# optional: Ed25519 private key (PEM) for detached signatures on
# court-export bundles. leave unset to skip signing.
# LOOM_BUNDLE_SIGNING_KEY=

# logging + debug
LOOM_DEBUG=false
LOOM_LOG_LEVEL=info

# database connection pool
LOOM_DB_POOL_SIZE=20
LOOM_DB_MAX_OVERFLOW=10
LOOM_DB_POOL_RECYCLE=3600
LOOM_DB_POOL_PRE_PING=true
LOOM_DB_POOL_TIMEOUT=30

# observability (OpenTelemetry)
LOOM_OTEL_ENABLED=false
LOOM_OTEL_SERVICE_NAME=loom-api
LOOM_OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# ──────────────────────────────────────────────────────────
# Backup
# ──────────────────────────────────────────────────────────

MINIO_BACKUP_BUCKET=loom-backups
LOCAL_RETENTION_DAYS=7
REMOTE_RETENTION_DAYS=30
# set to gpg recipient email/key-id for encrypted backups
BACKUP_GPG_RECIPIENT=

# ──────────────────────────────────────────────────────────
# Nginx (production profile only)
# ──────────────────────────────────────────────────────────

NGINX_PORT=8888
NGINX_TLS_PORT=8443
# directory containing fullchain.pem and privkey.pem
TLS_CERT_DIR=./docker/nginx/certs

# ──────────────────────────────────────────────────────────
# Observability (observability profile only)
# ──────────────────────────────────────────────────────────

# grafana admin password. compose refuses to start without it set.
GRAFANA_ADMIN_PASSWORD=changeme
GRAFANA_PORT=3001

JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_BIND=127.0.0.1
