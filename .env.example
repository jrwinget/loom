# ──────────────────────────────────────────────────────────
# SECURITY WARNING: All values below are dev defaults.
# For production, replace ALL credentials with strong,
# unique values. Never deploy with these defaults.
# ──────────────────────────────────────────────────────────

# postgres
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom_dev
POSTGRES_DB=loom
POSTGRES_PORT=5432
POSTGRES_BIND=127.0.0.1

# minio
MINIO_ROOT_USER=loom_minio
MINIO_ROOT_PASSWORD=loom_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BIND=127.0.0.1

# temporal
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
TEMPORAL_BIND=127.0.0.1

# backend
LOOM_DATABASE_URL=postgresql+asyncpg://loom:loom_dev@localhost:5432/loom
LOOM_MINIO_ENDPOINT=localhost:9000
LOOM_MINIO_ACCESS_KEY=loom_minio
LOOM_MINIO_SECRET_KEY=loom_minio_dev
LOOM_MINIO_SECURE=false
LOOM_TEMPORAL_HOST=localhost:7233
LOOM_SECRET_KEY=change-me-in-production
LOOM_CORS_ORIGINS=["http://localhost:3000"]

# backup
MINIO_BACKUP_BUCKET=loom-backups
LOCAL_RETENTION_DAYS=7
REMOTE_RETENTION_DAYS=30
# set to gpg recipient email/key-id for encrypted backups
BACKUP_GPG_RECIPIENT=

# nginx (production profile only)
NGINX_PORT=8888
NGINX_TLS_PORT=8443
# directory containing fullchain.pem and privkey.pem
TLS_CERT_DIR=./docker/nginx/certs

# jaeger (observability profile only)
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_BIND=127.0.0.1
