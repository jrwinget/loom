# postgres
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom_dev
POSTGRES_DB=loom
POSTGRES_PORT=5432

# minio
MINIO_ROOT_USER=loom_minio
MINIO_ROOT_PASSWORD=loom_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# temporal
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080

# backend
LOOM_DATABASE_URL=postgresql+asyncpg://loom:loom_dev@localhost:5432/loom
LOOM_MINIO_ENDPOINT=localhost:9000
LOOM_MINIO_ACCESS_KEY=loom_minio
LOOM_MINIO_SECRET_KEY=loom_minio_dev
LOOM_MINIO_SECURE=false
LOOM_TEMPORAL_HOST=localhost:7233
LOOM_SECRET_KEY=change-me-in-production

# backup
MINIO_BACKUP_BUCKET=loom-backups
LOCAL_RETENTION_DAYS=7
REMOTE_RETENTION_DAYS=30

# nginx (production profile only)
NGINX_PORT=8888
